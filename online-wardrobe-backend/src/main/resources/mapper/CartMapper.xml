<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wardrobe.backend.mapper.CartMapper">

    <resultMap id="cartMap" type="com.wardrobe.backend.entity.Cart">
        <id column="id" property="id"/>
        <result column="cloth_id" property="clothId"/>
        <result column="cloth_size" property="clothSize"/>
        <result column="amount" property="amount"/>
        <result column="user_id" property="userId"/>
        <result column="date" property="date"/>
        <result column="cloth_name" property="clothName"/>
        <result column="image" property="image"/>
        <result column="price" property="price"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_cart (cloth_id, cloth_size, amount, user_id, date)
        VALUES (#{clothId}, #{clothSize}, #{amount}, #{userId}, #{date})
    </insert>

    <update id="updateAmount">
        UPDATE t_cart SET amount = #{amount} WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM t_cart WHERE id = #{id}
    </delete>

    <delete id="deleteByIds">
        DELETE FROM t_cart WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </delete>

    <select id="findById" resultType="com.wardrobe.backend.entity.Cart">
        SELECT * FROM t_cart WHERE id = #{id}
    </select>

    <select id="findByUserId" resultMap="cartMap">
        SELECT c.*, t.cloth_name, t.image, t.price
        FROM t_cart c
        LEFT JOIN t_clothes t ON c.cloth_id = t.id
        WHERE c.user_id = #{userId}
        ORDER BY c.id
    </select>

</mapper>
