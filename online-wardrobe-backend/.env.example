# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/wardrobe?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
DB_USERNAME=one
DB_PASSWORD=your_db_password_here

# JWT 配置
JWT_SECRET=change-me-to-a-random-string-at-least-256-bits
JWT_EXPIRATION=3600000

# 管理员种子账号（首次启动时自动创建）
ADMIN_SEED_PASSWORD=change-me-to-a-strong-password
